{
  "name": "chatbox",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -- turbo dev",
    "dev:server": "dotenv -- turbo dev --filter=chat --filter=identity --filter=persister",
    "dev:web": "dotenv -- turbo dev --filter=web",
    "simulator": "dotenv -- turbo dev --filter=simulator",
    "watch:dev": "dotenv -- turbo watch dev",
    "test": "dotenv -- turbo run test --concurrency=1",
    "test:e2e": "dotenv -- pnpm -F test-e2e test:e2e",
    "kill": "turbo run kill",
    "vet": "turbo run vet",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "seed":"dotenv -- pnpm -F persistence seed",
    "seed:full":"dotenv -- pnpm -F persistence seed:full",
    "push":"dotenv -- pnpm -F persistence push"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.7.4",
    "tsdown": "0.19.0-beta.5",
    "tsx": "^4.21.0",
    "turbo": "^2.7.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.27.0"
}
