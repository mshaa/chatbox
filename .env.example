# Common
NODE_ENV=development

# Auth
AUTH_JWT_SECRET=dev_secret_key_min_32_characters
AUTH_JWT_EXPIRES_IN_SEC=604800
AUTH_SOCKET_TOKEN_EXPIRES_IN_SEC=300
AUTH_COOKIE_SECURE=false
AUTH_REFRESH_TOKEN_EXPIRES_IN_SEC=604800
AUTH_ACCESS_TOKEN_EXPIRES_IN_SEC=900
AUTH_REFRESH_TOKEN_REUSE_WINDOW_SEC=10
AUTH_ARGON2_MEMORY_COST=4096
AUTH_ARGON2_TIME_COST=1
AUTH_ARGON2_PARALLELISM=1

# Security
SECURITY_BODY_SIZE_LIMIT=100kb

# Throttling / Rate Limiting
THROTTLE_ENABLED=false
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# for reference only, must be set on decorator level in controller
THROTTLE_AUTH_LIMIT=10

# WebSocket Rate Limiting (Chat Service)
CHAT_WEBSOCKET_RL_TYPING_POINTS=10
CHAT_WEBSOCKET_RL_TYPING_DURATION=10
CHAT_WEBSOCKET_RL_TYPING_BLOCK_DURATION=30

PERSISTENCE_STORAGE_URL=postgresql://chatbox:chatbox@localhost:5432/chatbox
PERSISTENCE_POOL_MAX=20
PERSISTENCE_LOGGER_ENABLED=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Queue
JOB_SYNC_LAST_READ_INTERVAL_MS=10000
PERSIST_READ_MSG_ID=write-behind

# Cache TTLs (seconds)
CACHE_TTL_ROOMS_DISCOVER=60
CACHE_TTL_ROOM_MEMBERS=120
CACHE_TTL_USER_PROFILE=300

# Apps
IDENTITY_PROTOCOL=http
IDENTITY_HOST=localhost
IDENTITY_PORT=3001
CHAT_PROTOCOL=http
CHAT_HOST=localhost
CHAT_PORT=3002
CHAT_WEBSOCKET_URL=/chat
CHAT_WEBSOCKET_PATH=/socket
CHAT_WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,https://admin.socket.io

# Web | WEBSOCKET_* duplicates CHAT_WEBSOCKET_* for nextjs
NEXT_PUBLIC_WEBSOCKET_URL=http://localhost:3002/chat
NEXT_PUBLIC_WEBSOCKET_PATH=/socket
NEXT_PUBLIC_PAGE_SIZE=20
NEXT_PUBLIC_AUTH_SOCKET_TOKEN_EXPIRES_IN_SEC=300

# Metrics / Observability
METRICS_ENABLED=false
METRICS_PATH=/metrics
METRICS_DEFAULT_METRICS=true

# Chat Simulator
SIMULATOR_MAX_BOTS=5
SIMULATOR_MIN_MESSAGE_INTERVAL_MS=40000
SIMULATOR_MAX_MESSAGE_INTERVAL_MS=80000
SIMULATOR_RESPONSE_CHANCE=0.7
SIMULATOR_TYPING_INDICATOR_CHANCE=1
SIMULATOR_MIN_TYPING_DURATION_MS=5000
SIMULATOR_MAX_TYPING_DURATION_MS=20000
SIMULATOR_ACTIVE_HOURS_START=0
SIMULATOR_ACTIVE_HOURS_END=24
SIMULATOR_PRE_SELECTED_ROOM=
SIMULATOR_BOT_DIST_ACTIVE_CHATTER=1
SIMULATOR_BOT_DIST_CASUAL_USER=0
SIMULATOR_BOT_DIST_LURKER=0
SIMULATOR_BOT_DIST_DM_ENTHUSIAST=0
