{
  "name": "@chatbox/contracts",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "vet": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write . --ignore-path ../../.gitignore"
  },
  "dependencies": {
    "@chatbox/persistence": "workspace:*",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@chatbox/config-eslint": "workspace:*",
    "@chatbox/config-prettier": "workspace:*",
    "@chatbox/config-tsdown": "workspace:*",
    "@chatbox/config-typescript": "workspace:*",
    "eslint": "^9.39.2"
  }
}
