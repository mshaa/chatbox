{
  "name": "@chatbox/nest-auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "vet": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write . --ignore-path ../../.gitignore"
  },
  "dependencies": {
    "@chatbox/nest-infra": "workspace:*",
    "@chatbox/nest-persistence": "workspace:*",
    "@chatbox/contracts": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "argon2": "^0.44.0",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@chatbox/config-eslint": "workspace:*",
    "@chatbox/config-prettier": "workspace:*",
    "@chatbox/config-tsdown": "workspace:*",
    "@chatbox/config-typescript": "workspace:*",
    "@types/express": "^4.17.21",
    "eslint": "^9.39.2"
  }
}
