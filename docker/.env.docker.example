# Docker network overrides - uses container names instead of localhost
PERSISTENCE_STORAGE_URL=postgresql://chatbox:chatbox@pgbouncer:5432/chatbox
PERSISTENCE_LOGGER_ENABLED=false

REDIS_HOST=chatbox_redis

# Server-side calls (BFF proxy, auth actions) - direct to service containers
IDENTITY_HOST=identity
CHAT_HOST=chat

# Browser-side calls - routed through Traefik on port 80
NEXT_PUBLIC_WEBSOCKET_URL=/chat
NEXT_PUBLIC_WEBSOCKET_PATH=/socket

CHAT_WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,https://admin.socket.io

NODE_ENV=production

METRICS_ENABLED=true